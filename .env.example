# .env.example — copy to .env.local and fill in values

# AI API
GEMINI_API_KEY=your-gemini-api-key-here

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key
SUPABASE_SECRET_KEY=your-supabase-service-role-key

# Admin identity — the Supabase auth.users UUID of the designated admin account
# NEVER commit the real value; keep this secret.
ADMIN_USER_ID=your-admin-supabase-user-uuid
ADMIN_EMAIL=admin@yourdomain.com

# Google AdSense Integration
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_ENABLED=false
NEXT_PUBLIC_ADSENSE_SHOW_PLACEHOLDERS=false

# Individual Ad Slot IDs (get these from AdSense dashboard after approval)
NEXT_PUBLIC_AD_SLOT_HEADER_BANNER=
NEXT_PUBLIC_AD_SLOT_IN_ARTICLE=
NEXT_PUBLIC_AD_SLOT_SIDEBAR=
NEXT_PUBLIC_AD_SLOT_BELOW_RECIPE=
NEXT_PUBLIC_AD_SLOT_BETWEEN_POSTS=
